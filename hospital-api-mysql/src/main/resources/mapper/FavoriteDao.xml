<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.hospital.api.db.dao.FavoriteDao">

    <sql id="whereSql">
        <where>
            <if test="doctorId != null">
                AND f.doctor_id = #{doctorId}
            </if>
            <if test="doctorName != null and doctorName != ''">
                AND d.name LIKE CONCAT('%', #{doctorName}, '%')
            </if>
            <if test="patientName != null and patientName != ''">
                AND c.name LIKE CONCAT('%', #{patientName}, '%')
            </if>
            <if test="patientTel != null and patientTel != ''">
                AND c.tel = #{patientTel}
            </if>
            <if test="startDate != null and startDate != ''">
                AND f.create_time <![CDATA[>=]]> STR_TO_DATE(#{startDate}, '%Y-%m-%d')
            </if>
            <if test="endDate != null and endDate != ''">
                AND f.create_time <![CDATA[<]]> DATE_ADD(STR_TO_DATE(#{endDate}, '%Y-%m-%d'), INTERVAL 1 DAY)
            </if>
        </where>
    </sql>

    <select id="searchCount" parameterType="Map" resultType="long">
        SELECT COUNT(*)
        FROM patient_doctor_favorite f
                 JOIN doctor d ON d.id = f.doctor_id
                 JOIN patient_user_info_card c ON c.id = f.patient_card_id
        <include refid="whereSql"/>
    </select>

    <select id="searchByPage" parameterType="Map" resultType="HashMap">
        SELECT f.id,
               f.doctor_id AS doctorId,
               f.patient_card_id AS patientCardId,
               d.name AS doctorName,
               d.job,
               c.name AS patientName,
               c.tel AS patientTel,
               DATE_FORMAT(f.create_time, '%Y-%m-%d %H:%i') AS createTime
        FROM patient_doctor_favorite f
                 JOIN doctor d ON d.id = f.doctor_id
                 JOIN patient_user_info_card c ON c.id = f.patient_card_id
        <include refid="whereSql"/>
        ORDER BY f.create_time DESC
        LIMIT #{length} OFFSET #{start}
    </select>
</mapper>
